{
  "name": "@outgate/guardrail",
  "version": "1.0.0",
  "description": "Guardrail service for intelligent request filtering and content security",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/prompts dist/prompts",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "benchmark": "ts-node src/benchmark/cli.ts",
    "benchmark:verbose": "ts-node src/benchmark/cli.ts --verbose",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "node-fetch": "^2.7.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Outgate.ai",
  "license": "MIT"
}
