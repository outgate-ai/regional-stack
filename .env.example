# Regional stack local environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Region identity (from POST /api/regions response)
REGION_ID=reg-xxxxxxxxxxxx
ORGANIZATION_ID=o-xxxxxxxxxxxx

# BFF base URL
BFF_BASE_URL=https://your-api-gateway.execute-api.eu-central-1.amazonaws.com

# Secrets (from POST /api/regions and GET /api/regions/{id}/compose)
WEBHOOK_SECRET=your-webhook-secret
INTERNAL_API_KEY=your-internal-api-key

# Internal service passwords (generate random values)
KONG_DB_PASSWORD=change-me-random-password
REDIS_PASSWORD=change-me-random-password

# Guardrail LLM configuration
GUARDRAIL_LLM_PROVIDER=ollama
GUARDRAIL_LLM_ENDPOINT=http://host.docker.internal:11434/api
GUARDRAIL_LLM_MODEL=your-model-name
# GUARDRAIL_LLM_TOKEN=          # optional, for token-authenticated LLM providers

# AWS configuration (for SQS polling in private mode)
AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=             # required for private (SQS) regions
# AWS_SECRET_ACCESS_KEY=         # required for private (SQS) regions
# SQS_QUEUE_URL=                 # required for private (SQS) regions

# HTTP mode (set to true for local development / public regions)
HTTP_ENABLED=true
# REGION_ENDPOINT=               # public region URL, e.g. https://reg-xxx.yourdomain.com

# --- Below have sensible defaults; override only if needed ---

# Kong gateway (defaults shown)
# KONG_PROXY_LISTEN=0.0.0.0:8000, 0.0.0.0:8443 ssl
# KONG_ADMIN_LISTEN=0.0.0.0:8001
# KONG_LOG_LEVEL=info
# KONG_PLUGINS=bundled,pre-function,rate-limiting,key-auth,acl,http-log,response-transformer,request-transformer
# KONG_UNTRUSTED_LUA=on
# KONG_UNTRUSTED_LUA_SANDBOX_REQUIRES=cjson,cjson.safe
# KONG_NGINX_HTTP_LUA_SHARED_DICT=request_bodies 10m
# KONG_NGINX_PROXY_CLIENT_BODY_BUFFER_SIZE=2m

# Log manager tuning (defaults shown)
# MAX_REQUEST_SIZE=10mb
# REDIS_RETRY_BASE_MS=50
# REDIS_RETRY_MAX_MS=2000
# LOG_DEFAULT_TTL_SECONDS=86400
# LOG_TTL_MIN_SECONDS=3600
# LOG_TTL_MAX_SECONDS=2592000

# Metrics queue tuning (defaults shown)
# METRICS_MAX_CONCURRENT_JOBS=10
# METRICS_MAX_ATTEMPTS=3
# METRICS_RETRY_DELAY_MS=1000
# METRICS_JOB_TIMEOUT_MS=30000
# METRICS_CLEANUP_INTERVAL_MS=60000
# METRICS_MAX_COMPLETED_AGE_MS=86400000
# METRICS_MAX_FAILED_AGE_MS=604800000
# METRICS_PROCESSING_INTERVAL_MS=100

# Guardrail health check
# GUARDRAIL_LLM_HEALTH_TIMEOUT_MS=3000
# LOG_MANAGER_URL=http://log-manager:4001
